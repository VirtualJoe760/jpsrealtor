# ChatRealty API — used SERVER-SIDE ONLY (never exposed to the browser).
# `create-chatrealty-site` writes your real values into .env.local for you.
# Get a token from Settings → Integrations on your ChatRealty site.
CHATREALTY_API_TOKEN=crt_live_your_token_here
CHATREALTY_API_BASE=https://www.chatrealty.io

# CHAP — the on-site property chat. BYOK: any OpenAI-compatible provider.
# Groq (console.groq.com) is the recommended default. The widget hides itself
# until a key is set. SERVER-SIDE ONLY.
# CHAT_API_KEY=gsk_your_key_here
# CHAT_MODEL=llama-3.3-70b-versatile
# CHAT_BASE_URL=https://api.groq.com/openai/v1
