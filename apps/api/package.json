{
  "name": "@chatrealty/api",
  "version": "0.1.0",
  "private": true,
  "description": "ChatRealty product API — standalone NestJS surface that reuses the Next app's framework-agnostic core in ../../src/lib.",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build && tsc-alias -p tsconfig.build.json",
    "start": "node -r tsconfig-paths/register -r ts-node/register src/main.ts",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/apps/api/src/main.js",
    "start:built": "node dist/apps/api/src/main.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^8.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "class-validator": "^0.14.1",
    "class-transformer": "^0.5.1",
    "dotenv": "^16.5.0",
    "@neondatabase/serverless": "^0.10.4",
    "drizzle-orm": "^0.44.7",
    "lru-cache": "^11.5.1",
    "mongoose": "^8.15.1",
    "pg": "^8.16.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.10",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  }
}
